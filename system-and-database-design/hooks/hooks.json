{
  "description": "sdd plugin hooks — announces the plugin at session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/banner.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
